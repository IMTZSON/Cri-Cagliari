---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Sostituisci i placeholder colorati con le foto reali (come nella home)
const servizi = [
  { 
    id: "01",
    titolo: "Salute", 
    subtitle: "Soccorso e Assistenza Sanitaria", 
    testo: "Garantiamo il soccorso in emergenza-urgenza, il trasporto infermi per terapie e dimissioni, e l'assistenza sanitaria durante grandi eventi o manifestazioni sportive. Organizziamo inoltre corsi di Primo Soccorso e Manovre Salvavita per privati, scuole e aziende, diffondendo la cultura della prevenzione.", 
    foto: "/images/salute.webp",
    accent: "bg-red-500" 
  },
  { 
    id: "02",
    titolo: "Inclusione Sociale", 
    subtitle: "Supporto alle Vulnerabilità", 
    testo: "Lavoriamo per ridurre le cause di vulnerabilità individuali e ambientali. Le nostre attività includono la distribuzione di viveri alle famiglie in difficoltà, il supporto alle persone senza dimora tramite le Unità di Strada (UdS), e lo sportello sociale per l'orientamento ai servizi del territorio.", 
    foto: "/images/sociale.webp",
    accent: "bg-blue-500" 
  },
  { 
    id: "03",
    titolo: "Emergenze", 
    subtitle: "Protezione Civile e Risposta ai Disastri", 
    testo: "I nostri volontari sono addestrati per intervenire tempestivamente in caso di calamità naturali (alluvioni, incendi, terremoti). Gestiamo l'allestimento di campi di accoglienza, la logistica dell'emergenza, le telecomunicazioni e forniamo fondamentale supporto psicologico alle popolazioni colpite.", 
    foto: "/images/emergenza.webp",
    accent: "bg-orange-500" 
  },
  { 
    id: "04",
    titolo: "Giovani", 
    subtitle: "Educazione e Cittadinanza Attiva", 
    testo: "I Giovani della Croce Rossa promuovono l'educazione alla salute e stili di vita sani tra i loro coetanei. Organizziamo campagne nelle scuole e nelle piazze su tematiche come l'educazione stradale, la prevenzione delle malattie sessualmente trasmissibili, l'educazione alimentare e la promozione della donazione di sangue.", 
    foto: "/images/giovani.webp",
    accent: "bg-yellow-500" 
  }
];
---

<Layout title="Cosa Facciamo - CRI Cagliari">
  <Header />
  
  <div class="bg-white py-24 lg:py-32 border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <h1 class="text-sm font-bold text-cri-red uppercase tracking-widest mb-6">Le Aree di Intervento</h1>
      <h2 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-8 tracking-tight">Come aiutiamo il territorio.</h2>
      <p class="text-xl text-gray-500 font-light leading-relaxed">
        La Croce Rossa di Cagliari declina la sua azione attraverso attività mirate per rispondere in modo efficace e tempestivo ai bisogni della nostra comunità.
      </p>
    </div>
  </div>

  <main class="py-24 bg-[#FAFAFA]">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 space-y-32">
      
      {servizi.map((servizio, index) => (
        <div class="relative flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
          
          <div class={`w-full lg:w-1/2 relative ${index % 2 !== 0 ? 'lg:order-2' : ''}`}>
            <div class="aspect-[4/3] rounded-3xl overflow-hidden shadow-2xl relative">
              <div class="absolute inset-0 bg-gray-200">
                <img src={servizio.foto} alt={`Attività di ${servizio.titolo}`} class="w-full h-full object-cover" onerror="this.style.display='none'" />
                <div class="absolute inset-0 bg-gradient-to-tr from-gray-800 to-gray-400 opacity-20"></div>
              </div>
            </div>
            <div class={`absolute -bottom-6 -left-6 lg:top-1/2 lg:-translate-y-1/2 lg:-left-12 ${index % 2 !== 0 ? 'lg:-left-auto lg:-right-12' : ''} bg-white text-gray-900 w-24 h-24 rounded-full flex items-center justify-center text-3xl font-black shadow-xl border border-gray-100`}>
              {servizio.id}
            </div>
          </div>

          <div class={`w-full lg:w-1/2 ${index % 2 !== 0 ? 'lg:order-1' : ''}`}>
            <div class="flex items-center gap-3 mb-4">
              <span class={`w-3 h-3 rounded-full ${servizio.accent}`}></span>
              <span class="text-sm font-bold text-gray-400 uppercase tracking-widest">{servizio.subtitle}</span>
            </div>
            <h3 class="text-4xl font-bold text-gray-900 mb-6">{servizio.titolo}</h3>
            <p class="text-lg text-gray-600 leading-relaxed mb-8">
              {servizio.testo}
            </p>
            <a href={`/${servizio.titolo.toLowerCase()}`} class="inline-flex items-center gap-2 text-cri-red font-semibold hover:gap-4 transition-all group">
              Approfondisci i servizi
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
          
        </div>
      ))}

    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8 mt-40">
      <div class="bg-cri-dark rounded-[2.5rem] p-12 lg:p-20 relative overflow-hidden flex flex-col lg:flex-row items-center justify-between gap-12 shadow-2xl">
        <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-cri-red/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
        <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-white/5 rounded-full blur-2xl translate-y-1/2 -translate-x-1/4"></div>
        
        <div class="relative z-10 lg:w-2/3">
          <h4 class="text-3xl lg:text-4xl font-bold text-white mb-6">Diventa la risposta ai bisogni della tua città.</h4>
          <p class="text-xl text-gray-300 font-light max-w-2xl">
            Il modo migliore per comprendere il valore di questi servizi è viverli in prima persona. Unisciti a noi e scopri quanto può essere gratificante donare il proprio tempo.
          </p>
        </div>
        
        <div class="relative z-10 lg:w-1/3 flex justify-end">
          <a href="/diventa-volontario" class="bg-cri-red text-white font-bold px-8 py-4 rounded-xl hover:bg-white hover:text-cri-dark transition-colors duration-300 shadow-lg whitespace-nowrap">
            Diventa Volontario
          </a>
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>