---
// src/pages/notizie.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

// 1. Recupera tutte le notizie 
const tutteLeNotizie = await getCollection('notizie', ({ data }) => {
  return data.bozza !== true;
});

// 2. Ordina le notizie per data (ATTENZIONE: ora usiamo data.date)
const notizieOrdinate = tutteLeNotizie.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Notizie ed Eventi - CRI Cagliari">
  <Header />
  
  <div class="bg-white py-20 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <h1 class="text-sm font-bold text-cri-red uppercase tracking-widest mb-4">News ed Eventi</h1>
      <h2 class="text-5xl font-bold text-gray-900">Le ultime dal Comitato</h2>
    </div>
  </div>

  <main class="py-20 bg-gray-50 flex-grow">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      
      {notizieOrdinate.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-xl text-gray-500">Al momento non ci sono notizie pubblicate.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
          {notizieOrdinate.map((notizia) => (
            <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-300 border border-gray-100 flex flex-col group">
               
              <div class="aspect-[16/9] overflow-hidden bg-gray-200">
                {notizia.data.immagine ? (
                  <img 
                    src={notizia.data.immagine} 
                    alt={notizia.data.title} 
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                  />
                ) : (
                  <div class="w-full h-full bg-gradient-to-tr from-gray-100 to-gray-300 flex items-center justify-center">
                    <span class="text-gray-400 font-bold uppercase text-xs tracking-widest">CRI Cagliari</span>
                  </div>
                )}
              </div>
              
              <div class="p-8 flex flex-col flex-grow">
                <div class="flex items-center justify-between mb-4">
                  <span class="text-xs font-bold text-cri-red uppercase tracking-wider bg-red-50 px-3 py-1 rounded-full">
                    {notizia.data.categoria}
                  </span>
                  <time class="text-sm text-gray-500">
                    {notizia.data.date.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </div>
                
                <h3 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-cri-red transition-colors">
                  <a href={`/notizie/${notizia.id}`}>{notizia.data.title}</a>
                </h3>
                
                <p class="text-gray-600 line-clamp-3 mb-6 flex-grow">
                  {notizia.data.estratto}
                </p>
                
                <div class="mt-auto pt-6 border-t border-gray-100">
                  <a href={`/notizie/${notizia.id}`} class="inline-flex items-center gap-2 text-sm font-bold text-gray-900 hover:text-cri-red transition-colors">
                    Leggi l'articolo 
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
      
    </div>
  </main>
  
  <Footer />
</Layout>