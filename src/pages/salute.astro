---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Dati invariati, ma resi perfetti per un layout simmetrico
const servizi = [
  { 
    titolo: "Trasporto Infermi", 
    desc: "Organizziamo trasferimenti sicuri per pazienti verso ospedali, cliniche o dal domicilio. I nostri mezzi sono attrezzati per garantire il massimo comfort durante tutto il tragitto, assistiti da personale formato.",
    icona: "M13 10V3L4 14h7v7l9-11h-7z" 
  },
  { 
    titolo: "Grandi Eventi", 
    desc: "Dalle manifestazioni sportive ai concerti, garantiamo postazioni mediche avanzate e squadre di soccorso appiedate per intervenire tempestivamente e in sicurezza in luoghi affollati.",
    icona: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" 
  },
  { 
    titolo: "Corsi formativi", 
    desc: "Organizziamo regolarmente corsi di Primo Soccorso (PSTI), disostruzione pediatrica e uso del defibrillatore (BLSD) aperti a tutta la cittadinanza e alle aziende.",
    icona: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" 
  }
];
---

<Layout title="Salute e Soccorso - CRI Cagliari">
  <Header />
  
  <header class="relative bg-cri-dark pt-32 pb-40 overflow-hidden isolate border-b-8 border-cri-red">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900 via-gray-900/90 to-transparent z-10"></div>
      <img src="/images/salute.webp" alt="Soccorso Sanitario CRI" class="w-full h-full object-cover opacity-40 mix-blend-luminosity" onerror="this.style.display='none'"/>
    </div>
    
    <div class="relative z-20 max-w-7xl mx-auto px-6 lg:px-8 flex flex-col items-start">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-cri-red text-white font-bold uppercase tracking-widest text-xs mb-6 shadow-md">
        Area 1 - Salute
      </div>
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight leading-tight max-w-4xl">
        Tutela della Salute <br/>e della Vita
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 font-light leading-relaxed max-w-3xl border-l-4 border-cri-red pl-6">
        Garantiamo interventi tempestivi e professionali per proteggere la salute della nostra comunità. Un impegno costante, 24 ore su 24.
      </p>
    </div>
  </header>

  <main class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      
      <div class="bg-white border-l-8 border-cri-red p-8 md:p-12 shadow-sm flex flex-col md:flex-row gap-10 items-center mb-24 max-w-5xl mx-auto">
        <div class="md:w-2/3">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Più di una semplice ambulanza</h2>
          <p class="text-lg text-gray-600 leading-relaxed">
            L'intervento in emergenza è solo la punta dell'iceberg. L'Area Salute della Croce Rossa di Cagliari lavora costantemente sulla <strong>prevenzione</strong>, educando i cittadini alle manovre salvavita e garantendo un supporto sanitario programmato a chi non può muoversi autonomamente.
          </p>
        </div>
        <div class="md:w-1/3 bg-gray-50 p-6 rounded-lg text-center border border-gray-100">
           <svg class="w-12 h-12 text-cri-red mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
           <div class="text-4xl font-black text-gray-900 leading-none">112</div>
           <div class="text-xs font-bold text-gray-500 uppercase tracking-wider mt-2">Emergenza Medica</div>
        </div>
      </div>

      <div class="text-center mb-16">
        <h2 class="text-sm font-bold text-cri-red uppercase tracking-widest mb-2">I nostri servizi</h2>
        <h3 class="text-4xl font-bold text-gray-900">Come possiamo aiutarti</h3>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-32">
        {servizi.map((servizio) => (
          <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-200 hover:border-cri-red transition-colors duration-300 flex flex-col h-full group">
            
            <div class="w-14 h-14 bg-red-50 text-cri-red rounded flex items-center justify-center mb-6 group-hover:bg-cri-red group-hover:text-white transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={servizio.icona} />
              </svg>
            </div>
            
            <h4 class="text-2xl font-bold text-gray-900 mb-4">{servizio.titolo}</h4>
            
            <p class="text-gray-600 leading-relaxed flex-grow">{servizio.desc}</p>
          </div>
        ))}
      </div>

      <div class="bg-gray-900 rounded-xl p-10 md:p-16 text-center text-white shadow-lg flex flex-col md:flex-row items-center justify-between gap-8 border-t-4 border-cri-red">
        <div class="text-left md:w-2/3">
          <h3 class="text-3xl font-bold mb-4">Servizio Trasporti e Assistenza</h3>
          <p class="text-lg text-gray-400">
            Devi richiedere un trasferimento non urgente o un presidio sanitario per un evento pubblico? Il nostro Ufficio Servizi è a tua disposizione.
          </p>
        </div>
        <div class="md:w-1/3 flex justify-end">
          <a href="/contatti" class="inline-block bg-cri-red text-white font-bold px-8 py-4 hover:bg-red-700 transition-colors shadow-md uppercase tracking-wide text-sm">
            Richiedi un preventivo
          </a>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>