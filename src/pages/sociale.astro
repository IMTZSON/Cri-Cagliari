---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const servizi = [
  { titolo: "Distribuzione Viveri", desc: "Supportiamo le famiglie in difficoltà economica attraverso la distribuzione periodica di pacchi spesa e beni di prima necessità (Progetto AGEA)." },
  { titolo: "Unità di Strada", desc: "Le nostre squadre portano conforto, coperte, pasti caldi e assistenza di base alle persone senza dimora durante le ore serali e notturne." },
  { titolo: "Sportello Sociale", desc: "Un punto di ascolto attivo per orientare le persone vulnerabili verso i servizi del territorio e offrire supporto psicologico e amministrativo." }
];
---

<Layout title="Inclusione Sociale - CRI Cagliari">
  <Header />
  
  <header class="bg-[#111418] text-white pt-24 pb-32 border-b-8 border-blue-600">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-sm font-bold text-blue-500 uppercase tracking-widest mb-4 block">Area 2</span>
      <h1 class="text-5xl md:text-6xl font-bold mb-6">Inclusione Sociale</h1>
      <p class="text-xl text-gray-400 max-w-3xl mx-auto font-light">Promuoviamo lo sviluppo dell'individuo e costruiamo comunità più resilienti e inclusive, non lasciando indietro nessuno.</p>
    </div>
  </header>

  <main class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {servizi.map(servizio => (
          <div class="bg-white p-10 rounded-3xl shadow-sm border border-gray-100 hover:shadow-xl transition-shadow border-t-4 hover:border-t-blue-600">
            <h3 class="text-2xl font-bold text-gray-900 mb-4">{servizio.titolo}</h3>
            <p class="text-gray-600 leading-relaxed">{servizio.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>