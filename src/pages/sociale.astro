---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const servizi = [
  { 
    titolo: "Distribuzione Viveri", 
    desc: "Supportiamo le famiglie in difficoltà economica attraverso la distribuzione periodica di pacchi spesa e beni di prima necessità, in collaborazione con i servizi sociali.",
    icona: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" 
  },
  { 
    titolo: "Unità di Strada", 
    desc: "Le nostre squadre portano conforto, coperte, pasti caldi e assistenza di base alle persone senza dimora durante le ore serali e notturne, soprattutto nei mesi invernali.",
    icona: "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" 
  },
  { 
    titolo: "Sportello Sociale", 
    desc: "Un punto di ascolto attivo per orientare le persone vulnerabili verso i servizi del territorio e offrire un primo supporto amministrativo e relazionale.",
    icona: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" 
  }
];
---

<Layout title="Inclusione Sociale - CRI Cagliari">
  <Header />
  
  <header class="relative bg-cri-dark pt-32 pb-40 overflow-hidden isolate border-b-8 border-cri-red">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900 via-gray-900/90 to-transparent z-10"></div>
      <img src="/images/sociale.webp" alt="Inclusione Sociale CRI" class="w-full h-full object-cover opacity-40 mix-blend-luminosity" onerror="this.style.display='none'"/>
    </div>
    
    <div class="relative z-20 max-w-7xl mx-auto px-6 lg:px-8 flex flex-col items-start">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-cri-red text-white font-bold uppercase tracking-widest text-xs mb-6 shadow-md">
        Area 2 - Sociale
      </div>
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight leading-tight max-w-4xl">
        Vicini a chi <br/>ha più bisogno
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 font-light leading-relaxed max-w-3xl border-l-4 border-cri-red pl-6">
        Promuoviamo lo sviluppo dell'individuo e costruiamo comunità più resilienti e inclusive, non lasciando indietro nessuno.
      </p>
    </div>
  </header>

  <main class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      
      <div class="bg-white border-l-8 border-cri-red p-8 md:p-12 shadow-sm flex flex-col md:flex-row gap-10 items-center mb-24 max-w-5xl mx-auto">
        <div class="md:w-2/3">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Combattiamo le vulnerabilità</h2>
          <p class="text-lg text-gray-600 leading-relaxed">
            La Croce Rossa Italiana opera quotidianamente per alleviare la sofferenza delle fasce più deboli della popolazione. Il nostro approccio non è solo assistenziale, ma punta a restituire <strong>dignità e autonomia</strong> alle persone, accompagnandole in un percorso di reinserimento.
          </p>
        </div>
        <div class="md:w-1/3 bg-gray-50 p-6 rounded-lg text-center border border-gray-100">
           <svg class="w-12 h-12 text-cri-red mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
           <div class="text-4xl font-black text-gray-900 leading-none">1520</div>
           <div class="text-xs font-bold text-gray-500 uppercase tracking-wider mt-2">Numero Pubblica Utilità CRI</div>
        </div>
      </div>

      <div class="text-center mb-16">
        <h2 class="text-sm font-bold text-cri-red uppercase tracking-widest mb-2">I nostri servizi</h2>
        <h3 class="text-4xl font-bold text-gray-900">Le nostre attività sul territorio</h3>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-32">
        {servizi.map((servizio) => (
          <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-200 hover:border-cri-red transition-colors duration-300 flex flex-col h-full group">
            
            <div class="w-14 h-14 bg-red-50 text-cri-red rounded flex items-center justify-center mb-6 group-hover:bg-cri-red group-hover:text-white transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={servizio.icona} />
              </svg>
            </div>
            
            <h4 class="text-2xl font-bold text-gray-900 mb-4">{servizio.titolo}</h4>
            <p class="text-gray-600 leading-relaxed flex-grow">{servizio.desc}</p>
          </div>
        ))}
      </div>

      <div class="bg-gray-900 rounded-xl p-10 md:p-16 text-center text-white shadow-lg flex flex-col md:flex-row items-center justify-between gap-8 border-t-4 border-cri-red">
        <div class="text-left md:w-2/3">
          <h3 class="text-3xl font-bold mb-4">Sostieni le nostre attività sociali</h3>
          <p class="text-lg text-gray-400">
            Puoi aiutarci donando beni di prima necessità, devolvendo il tuo 5x1000 o dedicando il tuo tempo come volontario. Ogni gesto conta.
          </p>
        </div>
        <div class="md:w-1/3 flex justify-end">
          <a href="/diventa-volontario" class="inline-block bg-cri-red text-white font-bold px-8 py-4 hover:bg-red-700 transition-colors shadow-md uppercase tracking-wide text-sm">
            Diventa Volontario
          </a>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>