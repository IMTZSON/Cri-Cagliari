---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const servizi = [
  { 
    titolo: "Risposta ai Disastri", 
    desc: "Siamo pronti a intervenire tempestivamente in caso di calamità naturali (alluvioni, incendi, terremoti) per garantire ricerca, soccorso e assistenza immediata alla popolazione colpita.",
    icona: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" 
  },
  { 
    titolo: "Logistica Campale", 
    desc: "Allestiamo e gestiamo strutture di accoglienza temporanee (PMA, tendopoli), garantendo fornitura di pasti caldi, energia elettrica e comunicazioni d'emergenza.",
    icona: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" 
  },
  { 
    titolo: "Prevenzione Rischi", 
    desc: "Lavoriamo sulla resilienza della comunità formando la popolazione sui comportamenti corretti da adottare in caso di emergenza (campagne informative e Protezione Civile).",
    icona: "M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" 
  }
];
---

<Layout title="Emergenze e Protezione Civile - CRI Cagliari">
  <Header />
  
  <header class="relative bg-cri-dark pt-32 pb-40 overflow-hidden isolate border-b-8 border-cri-red">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900 via-gray-900/90 to-transparent z-10"></div>
      <img src="/images/emergenza.webp" alt="Protezione Civile CRI" class="w-full h-full object-cover opacity-40 mix-blend-luminosity" onerror="this.style.display='none'"/>
    </div>
    
    <div class="relative z-20 max-w-7xl mx-auto px-6 lg:px-8 flex flex-col items-start">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-cri-red text-white font-bold uppercase tracking-widest text-xs mb-6 shadow-md">
        Area 3 - Emergenze
      </div>
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight leading-tight max-w-4xl">
        Sempre pronti, <br/>sempre operativi
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 font-light leading-relaxed max-w-3xl border-l-4 border-cri-red pl-6">
        Prepariamo la comunità e rispondiamo in modo tempestivo ed efficace a calamità naturali e crisi di ogni tipo, inseriti nel sistema di Protezione Civile.
      </p>
    </div>
  </header>

  <main class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      
      <div class="bg-white border-l-8 border-cri-red p-8 md:p-12 shadow-sm flex flex-col md:flex-row gap-10 items-center mb-24 max-w-5xl mx-auto">
        <div class="md:w-2/3">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Il Sistema di Protezione Civile</h2>
          <p class="text-lg text-gray-600 leading-relaxed">
            I Volontari CRI impiegati nelle attività di emergenza seguono rigidi protocolli di addestramento. Grazie alla nostra struttura capillare sul territorio, la CRI è Struttura Operativa Nazionale del Servizio di Protezione Civile, capace di mobilitare uomini e mezzi in poche ore.
          </p>
        </div>
        <div class="md:w-1/3 bg-gray-50 p-6 rounded-lg text-center border border-gray-100">
           <svg class="w-12 h-12 text-cri-red mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
           <div class="text-4xl font-black text-gray-900 leading-none">24/7</div>
           <div class="text-xs font-bold text-gray-500 uppercase tracking-wider mt-2">Reperibilità Operativa</div>
        </div>
      </div>

      <div class="text-center mb-16">
        <h2 class="text-sm font-bold text-cri-red uppercase tracking-widest mb-2">Le Nostre Attività</h2>
        <h3 class="text-4xl font-bold text-gray-900">Prevenzione e Risposta</h3>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-32">
        {servizi.map((servizio) => (
          <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-200 hover:border-cri-red transition-colors duration-300 flex flex-col h-full group">
            
            <div class="w-14 h-14 bg-red-50 text-cri-red rounded flex items-center justify-center mb-6 group-hover:bg-cri-red group-hover:text-white transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={servizio.icona} />
              </svg>
            </div>
            
            <h4 class="text-2xl font-bold text-gray-900 mb-4">{servizio.titolo}</h4>
            <p class="text-gray-600 leading-relaxed flex-grow">{servizio.desc}</p>
          </div>
        ))}
      </div>

      <div class="bg-gray-900 rounded-xl p-10 md:p-16 text-center text-white shadow-lg flex flex-col md:flex-row items-center justify-between gap-8 border-t-4 border-cri-red">
        <div class="text-left md:w-2/3">
          <h3 class="text-3xl font-bold mb-4">Entra nella squadra Emergenze</h3>
          <p class="text-lg text-gray-400">
            Diventando volontario potrai specializzarti nella risposta ai disastri: dagli operatori radio, ai logisti, fino ai soccorritori con mezzi speciali.
          </p>
        </div>
        <div class="md:w-1/3 flex justify-end">
          <a href="/diventa-volontario" class="inline-block bg-cri-red text-white font-bold px-8 py-4 hover:bg-red-700 transition-colors shadow-md uppercase tracking-wide text-sm">
            Scopri i Corsi
          </a>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>