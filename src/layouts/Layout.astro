---
// IMPORTANTE: Questa riga carica Tailwind in tutto il sito.
// Il percorso DEVE corrispondere alla cartella dove hai salvato global.css
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="it">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Croce Rossa Italiana - Comitato di Cagliari " />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
		
		<title>{title} | CRI Cagliari</title>
	</head>
	<body class="bg-white text-gray-900 selection:bg-cri-red selection:text-white">
		<slot />
	</body>
</html>