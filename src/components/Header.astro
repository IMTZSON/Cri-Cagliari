---
// Componente Header.astro aggiornato con logo reale Cagliari
---

<header class="bg-white shadow-md sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-24">
      
      <div class="flex-shrink-0 flex items-center h-full py-4">
        <a href="/" class="flex items-center h-full">
          <img 
            src="/loghi/logo-cagliari.png" 
            alt="Croce Rossa Italiana - Comitato di Cagliari" 
            class="h-full w-auto object-contain" 
          />
        </a>
      </div>

      <nav class="hidden md:flex space-x-8">
        <a href="/chi-siamo" class="text-gray-700 hover:text-cri-red font-semibold transition">Chi siamo</a>
        <a href="/cosa-facciamo" class="text-gray-700 hover:text-cri-red font-semibold transition">Cosa facciamo</a>
        <a href="/notizie" class="text-gray-700 hover:text-cri-red font-semibold transition">Notizie</a>
        <a href="/contatti" class="text-gray-700 hover:text-cri-red font-semibold transition">Contatti</a>
      </nav>

      <div class="hidden md:flex items-center space-x-4">
        <a href="/diventa-volontario" class="text-cri-red font-bold hover:underline">Diventa volontario</a>
        <a href="/dona" class="bg-cri-red hover:bg-red-700 text-white px-6 py-2 rounded font-bold transition">
          Dona ora
        </a>
      </div>

      <div class="md:hidden flex items-center">
        <button class="text-gray-700 hover:text-cri-red focus:outline-none">
          <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
      
    </div>
  </div>
</header>